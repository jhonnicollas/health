---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CTASection from "@/components/common/CTASection.astro";
import { t } from "@/i18n/translations";

const locale = "id" as const;
const alternateUrls = {
  id: `https://isehat.biz.id${Astro.url.pathname}`,
  en: `https://isehat.biz.id/en${Astro.url.pathname}`,
};
---

<BaseLayout title={t(locale, "usecase.bp.title")} description={t(locale, "usecase.bp.subtitle")} locale={locale} alternateUrls={alternateUrls}>
  <section class="section-padding">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-6" style="color: var(--color-text);">{t(locale, "usecase.bp.title")}</h1>
      <p class="text-lg mb-8" style="color: var(--color-text-muted);">{t(locale, "usecase.bp.subtitle")}</p>

      <div class="space-y-8">
        <div class="card">
          <h2 class="text-xl font-bold mb-3" style="color: var(--color-text);">📸 {t(locale, "usecase.bp.photo")}</h2>
          <p class="text-sm" style="color: var(--color-text-muted);">{t(locale, "usecase.bp.photo.desc")}</p>
        </div>
        <div class="card">
          <h2 class="text-xl font-bold mb-3" style="color: var(--color-text);">✋ {t(locale, "usecase.bp.manual")}</h2>
          <p class="text-sm" style="color: var(--color-text-muted);">{t(locale, "usecase.bp.manual.desc")}</p>
        </div>
        <div class="card">
          <h2 class="text-xl font-bold mb-3" style="color: var(--color-text);">📊 {t(locale, "usecase.bp.rule")}</h2>
          <p class="text-sm" style="color: var(--color-text-muted);">{t(locale, "usecase.bp.rule.desc")}</p>
        </div>
        <div class="card">
          <h2 class="text-xl font-bold mb-3" style="color: var(--color-text);">📈 {t(locale, "usecase.bp.trend")}</h2>
          <p class="text-sm" style="color: var(--color-text-muted);">{t(locale, "usecase.bp.trend.desc")}</p>
        </div>
        <div class="card">
          <h2 class="text-xl font-bold mb-3" style="color: var(--color-text);">📄 {t(locale, "usecase.bp.report")}</h2>
          <p class="text-sm" style="color: var(--color-text-muted);">{t(locale, "usecase.bp.report.desc")}</p>
        </div>
      </div>
    </div>
  </section>
  <CTASection locale={locale} />
</BaseLayout>

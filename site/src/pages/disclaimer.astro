---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { t } from "@/i18n/translations";

const locale = "id" as const;
const alternateUrls = {
  id: `https://isehat.biz.id${Astro.url.pathname}`,
  en: `https://isehat.biz.id/en${Astro.url.pathname}`,
};
---

<BaseLayout title={t(locale, "disclaimerPage.title")} description={t(locale, "disclaimer.site")} locale={locale} alternateUrls={alternateUrls}>
  <section class="section-padding">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold mb-6" style="color: var(--color-text);">{t(locale, "disclaimerPage.title")}</h1>

      <div class="medical-disclaimer mb-8" style="font-size: 1rem;">
        <p><strong>Penting:</strong> {t(locale, "disclaimer.hero")}</p>
      </div>

      <div class="space-y-6 text-base" style="color: var(--color-text-muted);">
        <h2 class="text-2xl font-bold" style="color: var(--color-text);">Apa yang iSehat Lakukan</h2>
        <ul class="space-y-2 list-none">
          <li class="flex items-start gap-2"><span style="color: var(--color-success);">✓</span> Membantu mencatat data pengukuran kesehatan</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-success);">✓</span> Menampilkan interpretasi berbasis aturan terstruktur</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-success);">✓</span> AI membantu membaca angka dari foto alat kesehatan</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-success);">✓</span> User memverifikasi data sebelum disimpan</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-success);">✓</span> Membuat laporan untuk dibawa ke dokter</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-success);">✓</span> Edukasi kesehatan umum</li>
        </ul>

        <h2 class="text-2xl font-bold" style="color: var(--color-text);">Apa yang iSehat TIDAK Lakukan</h2>
        <ul class="space-y-2 list-none">
          <li class="flex items-start gap-2"><span style="color: var(--color-danger);">✗</span> Mendiagnosis penyakit</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-danger);">✗</span> Memberikan resep obat</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-danger);">✗</span> Mengatur dosis obat</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-danger);">✗</span> Menggantikan dokter</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-danger);">✗</span> Menentukan kondisi darurat</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-danger);">✗</span> Menjamin kesembuhan</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

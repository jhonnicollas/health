---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { t } from "@/i18n/translations";

const locale = "id" as const;
const alternateUrls = {
  id: `https://isehat.biz.id${Astro.url.pathname}`,
  en: `https://isehat.biz.id/en${Astro.url.pathname}`,
};
---

<BaseLayout title={t(locale, "disclaimerPage.title")} description={t(locale, "disclaimer.site")} locale={locale} alternateUrls={alternateUrls}>
  <section class="section-padding">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold mb-6" style="color: var(--color-text);">{t(locale, "disclaimerPage.title")}</h1>

      <div class="medical-disclaimer mb-8" style="font-size: 1rem;">
        <p><strong>Penting:</strong> {t(locale, "disclaimer.hero")}</p>
      </div>

      <div class="space-y-6 text-base" style="color: var(--color-text-muted);">
        <h2 class="text-2xl font-bold" style="color: var(--color-text);">Apa yang iSehat Lakukan</h2>
        <ul class="space-y-2 list-none">
          <li class="flex items-start gap-2"><span style="color: var(--color-success);">✓</span> Membantu mencatat data pengukuran kesehatan</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-success);">✓</span> Menampilkan interpretasi berbasis aturan terstruktur</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-success);">✓</span> AI membantu membaca angka dari foto alat kesehatan</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-success);">✓</span> User memverifikasi data sebelum disimpan</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-success);">✓</span> Membuat laporan untuk dibawa ke dokter</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-success);">✓</span> Edukasi kesehatan umum</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-success);">✓</span> AI Clinical Copilot membantu memahami data kesehatan dengan 13-detector Safety Runtime</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-success);">✓</span> WhatsApp AI untuk edukasi dan emergency guidance</li>
        </ul>

        <h2 class="text-2xl font-bold" style="color: var(--color-text);">Mode AI dan Batasannya</h2>
        <p>iSehat AI Clinical Copilot beroperasi dalam 3 mode yang dikontrol oleh Super Admin:</p>
        <ul class="space-y-2 list-none">
          <li class="flex items-start gap-2"><span style="color: var(--color-info);">●</span> <strong>Standard</strong> (default): AI TIDAK memberi diagnosis final, TIDAK resep, TIDAK dosis. AI hanya membantu menjelaskan.</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-warning);">●</span> <strong>Proactive</strong>: AI BOLEH memberi diagnosis final, TAPI TIDAK resep obat, TIDAK dosis. Perubahan mode memerlukan persetujuan medical reviewer.</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-danger);">●</span> <strong>Super Aktif</strong>: AI BOLEH diagnosis final DAN resep obat DAN dosis. Perubahan mode memerlukan persetujuan medical reviewer.</li>
        </ul>
        <p class="text-sm" style="color: var(--color-text-muted);"><strong>Semua mode:</strong> AI TIDAK BOLEH mengubah/menghentikan obat pengguna. Setiap output AI melewati 13-detector Safety Runtime v2 dan selalu dilengkapi disclaimer medis otomatis.</p>

        <h2 class="text-2xl font-bold" style="color: var(--color-text);">Apa yang iSehat TIDAK Lakukan</h2>
        <ul class="space-y-2 list-none">
          <li class="flex items-start gap-2"><span style="color: var(--color-danger);">✗</span> Mendiagnosis penyakit (mode standard)</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-danger);">✗</span> Memberikan resep obat (mode standard dan proactive)</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-danger);">✗</span> Mengatur dosis obat (mode standard dan proactive)</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-danger);">✗</span> Menggantikan dokter</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-danger);">✗</span> Menentukan kondisi darurat tanpa rule deterministik</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-danger);">✗</span> Menjamin kesembuhan</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-danger);">✗</span> Mengubah/menghentikan obat pengguna (semua mode)</li>
          <li class="flex items-start gap-2"><span style="color: var(--color-danger);">✗</span> Menggunakan AI tanpa pengawasan Safety Runtime</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { t } from "@/i18n/translations";

const locale = "id" as const;
const alternateUrls = {
  id: `https://isehat.biz.id${Astro.url.pathname}`,
  en: `https://isehat.biz.id/en${Astro.url.pathname}`,
};
---

<BaseLayout title={t(locale, "about.title")} description={t(locale, "about.p1")} locale={locale} alternateUrls={alternateUrls}>
  <section class="section-padding">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-6" style="color: var(--color-text);">{t(locale, "about.title")}</h1>
      <div class="space-y-6 text-base" style="color: var(--color-text-muted);">
        <p>{t(locale, "about.p1")}</p>
        <p><strong style="color: var(--color-text);">{t(locale, "about.promise")}</strong> {t(locale, "about.promisetext")}</p>
        <p>iSehat membantu pengguna mencatat hasil tensi, gula darah, SpO2, berat badan, suhu tubuh, obat, hidrasi, puasa, keluhan harian, dan data keluarga dalam satu sistem yang rapi, aman, dan siap dibawa ke dokter.</p>

        <h2 class="text-2xl font-bold mt-8" style="color: var(--color-text);">{t(locale, "about.principles")}</h2>
        <ul class="space-y-3 list-none">
          <li class="flex items-start gap-2"><span style="color: var(--color-primary);">●</span> <span>Rule-first, AI-assisted. Status kesehatan ditentukan oleh aturan terstruktur.</span></li>
          <li class="flex items-start gap-2"><span style="color: var(--color-primary);">●</span> <span>Manual verification. Anda selalu memverifikasi data sebelum disimpan.</span></li>
          <li class="flex items-start gap-2"><span style="color: var(--color-primary);">●</span> <span>Consent-first. Akses keluarga dan caregiver memerlukan persetujuan.</span></li>
          <li class="flex items-start gap-2"><span style="color: var(--color-primary);">●</span> <span>Privacy-first. Data kesehatan adalah data sensitif.</span></li>
          <li class="flex items-start gap-2"><span style="color: var(--color-primary);">●</span> <span>Transparansi. Kami tidak mengklaim kemampuan yang tidak kami miliki.</span></li>
        </ul>

        <div class="medical-disclaimer">
          <p class="text-sm">{t(locale, "about.disclaimer")}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { t } from "@/i18n/translations";

const locale = "en" as const;
const alternateUrls = {
  id: `https://isehat.biz.id/about`,
  en: `https://isehat.biz.id/en/about`,
};
---

<BaseLayout title={t(locale, "about.title")} description={t(locale, "about.p1")} locale={locale} alternateUrls={alternateUrls}>
  <section class="section-padding">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-6" style="color: var(--color-text);">{t(locale, "about.title")}</h1>
      <div class="space-y-6 text-base" style="color: var(--color-text-muted);">
        <p>{t(locale, "about.p1")}</p>
        <p><strong style="color: var(--color-text);">{t(locale, "about.promise")}</strong> {t(locale, "about.promisetext")}</p>
        <p>iSehat helps users record blood pressure, blood sugar, SpO2, weight, body temperature, medication, hydration, fasting, daily symptoms, and family data in one organized, secure system ready to bring to your doctor.</p>

        <h2 class="text-2xl font-bold mt-8" style="color: var(--color-text);">{t(locale, "about.principles")}</h2>
        <ul class="space-y-3 list-none">
          <li class="flex items-start gap-2"><span style="color: var(--color-primary);">●</span> <span>Rule-first, AI-assisted. Health status determined by structured rules.</span></li>
          <li class="flex items-start gap-2"><span style="color: var(--color-primary);">●</span> <span>Manual verification. You always verify data before saving.</span></li>
          <li class="flex items-start gap-2"><span style="color: var(--color-primary);">●</span> <span>Consent-first. Family and caregiver access requires consent.</span></li>
          <li class="flex items-start gap-2"><span style="color: var(--color-primary);">●</span> <span>Privacy-first. Health data is sensitive data.</span></li>
          <li class="flex items-start gap-2"><span style="color: var(--color-primary);">●</span> <span>Transparency. We don't claim capabilities we don't have.</span></li>
        </ul>

        <div class="medical-disclaimer">
          <p class="text-sm">{t(locale, "about.disclaimer")}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { t } from "@/i18n/translations";

const locale = "en" as const;
const alternateUrls = {
  id: `https://isehat.biz.id/contact`,
  en: `https://isehat.biz.id/en/contact`,
};
---

<BaseLayout title={t(locale, "contact.title")} description={t(locale, "contact.subtitle")} locale={locale} alternateUrls={alternateUrls}>
  <section class="section-padding">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-6" style="color: var(--color-text);">{t(locale, "contact.title")}</h1>

      <div class="space-y-6 text-base mb-8" style="color: var(--color-text-muted);">
        <p>{t(locale, "contact.subtitle")}</p>
      </div>

      <form class="space-y-4 max-w-md" onsubmit="event.preventDefault(); alert('Contact form is being prepared. For now, please reach us via email or Telegram.');">
        <div>
          <label for="contact-name" class="block text-sm font-medium mb-1" style="color: var(--color-text);">{t(locale, "contact.name")}</label>
          <input id="contact-name" type="text" required class="w-full px-4 py-3 rounded-lg text-sm" style="background-color: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border);" />
        </div>
        <div>
          <label for="contact-email" class="block text-sm font-medium mb-1" style="color: var(--color-text);">{t(locale, "contact.email")}</label>
          <input id="contact-email" type="email" required class="w-full px-4 py-3 rounded-lg text-sm" style="background-color: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border);" />
        </div>
        <div>
          <label for="contact-subject" class="block text-sm font-medium mb-1" style="color: var(--color-text);">{t(locale, "contact.subject")}</label>
          <input id="contact-subject" type="text" required class="w-full px-4 py-3 rounded-lg text-sm" style="background-color: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border);" />
        </div>
        <div>
          <label for="contact-message" class="block text-sm font-medium mb-1" style="color: var(--color-text);">{t(locale, "contact.message")}</label>
          <textarea id="contact-message" rows="5" required class="w-full px-4 py-3 rounded-lg text-sm" style="background-color: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border);"></textarea>
        </div>
        <p class="text-xs" style="color: var(--color-warning);">⚠️ {t(locale, "contact.warning")}</p>
        <button type="submit" class="btn-primary">{t(locale, "contact.submit")}</button>
      </form>
    </div>
  </section>
</BaseLayout>

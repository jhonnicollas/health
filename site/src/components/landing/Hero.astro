---
import type { Locale } from "@/i18n/utils";
import { t } from "@/i18n/translations";
import { APP_SIGNUP_URL } from "@/data/navigation";

interface Props {
  locale?: Locale;
}

const { locale = "id" } = Astro.props;
---

<section class="section-padding" style="background: var(--gradient-hero);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6" style="color: var(--color-text);">
          {t(locale, "hero.headline")}
        </h1>
        <p class="text-lg md:text-xl mb-8" style="color: var(--color-text-muted);">
          {t(locale, "hero.subheadline")}
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={APP_SIGNUP_URL} class="btn-primary text-lg px-8 py-4">{t(locale, "hero.cta.primary")}</a>
          <a href="#workflow" class="btn-secondary text-lg px-8 py-4">{t(locale, "hero.cta.secondary")}</a>
        </div>
        <p class="text-xs mt-4" style="color: var(--color-text-muted);">{t(locale, "hero.trust")}</p>
      </div>
      <div class="relative">
        <div class="card p-0 overflow-hidden" style="box-shadow: var(--shadow-card);">
          <div class="p-4" style="background-color: var(--color-primary); color: var(--color-primary-foreground);">
            <div class="flex items-center gap-2 text-sm font-medium">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
              {t(locale, "hero.mock.title")}
            </div>
          </div>
          <div class="p-6 space-y-4" style="background-color: var(--color-surface);">
            <div class="grid grid-cols-3 gap-3">
              <div class="text-center p-3 rounded-lg" style="background-color: var(--color-bg-soft);">
                <div class="text-2xl font-bold" style="color: var(--color-primary);">120</div>
                <div class="text-xs" style="color: var(--color-text-muted);">{t(locale, "hero.mock.sistolik")}</div>
              </div>
              <div class="text-center p-3 rounded-lg" style="background-color: var(--color-bg-soft);">
                <div class="text-2xl font-bold" style="color: var(--color-primary);">80</div>
                <div class="text-xs" style="color: var(--color-text-muted);">{t(locale, "hero.mock.diastolik")}</div>
              </div>
              <div class="text-center p-3 rounded-lg" style="background-color: var(--color-bg-soft);">
                <div class="text-2xl font-bold" style="color: var(--color-primary);">98%</div>
                <div class="text-xs" style="color: var(--color-text-muted);">SpO2</div>
              </div>
            </div>
            <div class="p-3 rounded-lg" style="background-color: var(--color-bg-soft);">
              <div class="text-xs font-medium mb-1" style="color: var(--color-text-muted);">{t(locale, "hero.mock.status")}</div>
              <div class="text-sm font-semibold" style="color: var(--color-success);">{t(locale, "hero.mock.normal")}</div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div class="p-2 rounded-lg text-center" style="background-color: var(--color-bg-soft);">
                <div class="text-lg font-bold" style="color: var(--color-info);">7</div>
                <div class="text-xs" style="color: var(--color-text-muted);">{t(locale, "hero.mock.streak")}</div>
              </div>
              <div class="p-2 rounded-lg text-center" style="background-color: var(--color-bg-soft);">
                <div class="text-lg font-bold" style="color: var(--color-info);">6/8</div>
                <div class="text-xs" style="color: var(--color-text-muted);">{t(locale, "hero.mock.gelas")}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

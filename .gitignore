# Section B: Build/test/stress artifact patterns (no leading / = any depth; Sprint 6 add for lean agent context).

# TypeScript incremental build cache (regenerated on tsc).
*.tsbuildinfo

# Playwright HTML report + raw test artifacts (regenerated on test run).
playwright-report/
test-results/

# Test coverage HTML report (regenerated on `npm test -- --coverage`).
coverage/

# Stress-test run outputs (each run creates a new dated directory).
stress-results/
stress/results/
worker/scripts/e2e-uat-output*/

# Local-validation scratch sessions (AI Vision manual trace, ad-hoc curl).
# Note: *.tmp intentionally NOT added — over-broad, no observed .tmp source
# files in workflow. Scratch dirs are scoped to worker/ and web/ only.
worker/scratch/
web/scratch/
